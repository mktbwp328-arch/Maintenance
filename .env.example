# ===== คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง =====
PORT=3000

# ---------- ฐานข้อมูล Supabase / Postgres (ไม่บังคับ) ----------
# ถ้าเว้นว่าง ระบบจะใช้ไฟล์ JSON ในเครื่องแทน
# 1) รัน supabase_schema.sql ใน Supabase Dashboard → SQL Editor ก่อน
# 2) เอา connection string จาก Connect → Direct/Session Pooler (เครือข่าย IPv4 ใช้ Session Pooler)
#    URL-encode รหัสผ่านด้วย (เช่น @ = %40)
#    *** ไฟล์ .env เป็นความลับ ห้าม commit (.gitignore ไว้แล้ว) ***
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co

# ---------- การแจ้งเตือนทางอีเมล (SMTP) ----------
# ตัวอย่าง Gmail: ต้องเปิด 2-Step Verification แล้วสร้าง "App Password"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=ระบบแจ้งซ่อม MTD <your-email@gmail.com>
# อีเมลผู้รับการแจ้งเตือน (คั่นหลายอันด้วย ,)
NOTIFY_EMAIL_TO=maintenance@company.com,supervisor@company.com

# ---------- การแจ้งเตือนทาง LINE (Messaging API) ----------
# สร้าง Channel ที่ https://developers.line.biz/console/  → Messaging API
# คัดลอก Channel access token (long-lived) มาวางด้านล่าง
LINE_CHANNEL_ACCESS_TOKEN=
# ปลายทางที่จะส่งข้อความ: userId, groupId หรือ roomId
# (เพิ่มบอทเข้ากลุ่ม แล้วใช้ webhook ดู groupId หรือใช้ userId ของผู้ดูแล)
LINE_TO=

# ---------- แจ้งซ่อมผ่านไลน์ (LIFF) ----------
# 1) สร้าง LIFF app ใน LINE Developers (Messaging API channel → แท็บ LIFF)
#    - Endpoint URL: https://<โดเมนของคุณ>/liff.html
#    - Size: Full, ต้องเปิด "Scope: profile, openid"
# 2) เอา LIFF ID มาใส่ (รูปแบบ 1234567890-abcdEFGH)
LIFF_ID=
# Channel ID ของ channel ที่สร้าง LIFF (Settings → Channel ID) ใช้ตรวจสอบ ID token ฝั่ง server
LIFF_CHANNEL_ID=
